# Copy to .env.local for local form testing (gitignored)
RESEND_API_KEY=re_your_key_here

# Optional — after verifying mandelrealtygroup.com in Resend
# RESEND_FROM=Mandel Realty Group <info@mandelrealtygroup.com>

# Optional — point the form at a Supabase edge function instead of /api/audit
# VITE_AUDIT_API_URL=https://hyndmdjvjlsbthlqrxge.supabase.co/functions/v1/send-audit-lead

# Meta Pixel (Events Manager → Datasets → Mandel Realty Website)
# Already set in code as default; override here only if you need a different ID
# VITE_META_PIXEL_ID=1583026230149842

# --- Lead inbox (Supabase) ---
# Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Run supabase/leads.sql once in the SQL Editor

# --- Admin (/admin) ---
ADMIN_PASSWORD=choose-a-strong-password
# Optional; defaults to ADMIN_PASSWORD if unset
# ADMIN_SESSION_SECRET=long-random-string

# Optional: manually block call times (comma-separated ISO timestamps)
# BOOKED_CALL_ISOS=2026-07-25T18:00:00.000Z,2026-07-25T18:30:00.000Z
