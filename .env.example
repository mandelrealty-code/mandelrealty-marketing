# Copy to .env.local for local form testing (gitignored)
RESEND_API_KEY=re_your_key_here

# Optional — after verifying mandelrealtygroup.com in Resend
# RESEND_FROM=Mandel Realty Group <info@mandelrealtygroup.com>

# Optional — point the form at a Supabase edge function instead of /api/audit
