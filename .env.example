# Meta Pixel (Events Manager → Datasets → Mandel Realty Website)
# Already set in code as default; override here only if you need a different ID
# VITE_META_PIXEL_ID=1583026230149842

# Call booking conflict store (recommended for production)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
